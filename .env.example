# --- REQUIRED API KEYS ---

# Alpha Vantage (Get for free: https://www.alphavantage.co/support/#api-key)
# Used for: Real-time quotes, company overviews, and chart history.
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Finnhub (Get for free: https://finnhub.io/register)
# Used for: Analyst recommendation trends and market news.
FINNHUB_API_KEY=your_finnhub_key_here

# Google Gemini (Get for free: https://aistudio.google.com/app/apikey)
# Used for: Plain-English AI financial explanations and summaries.
GEMINI_API_KEY=your_gemini_key_here

# --- OPTIONAL CONFIG ---

# Set to 'true' to use local mock data instead of live API calls (good for development).
USE_MOCK_DATA=false

# Root URL (Required for server-side fetches in Next.js 14+)
# On Vercel, this is automatically handled via NEXT_PUBLIC_URL logic.
# For local dev, this defaults to http://localhost:3000.
NEXT_PUBLIC_URL=http://localhost:3000
